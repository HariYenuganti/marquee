# Database connection string
DATABASE_URL="postgresql://user:password@localhost:5432/evento"

# Resend API key for booking confirmation emails (https://resend.com)
RESEND_API_KEY="re_your_api_key_here"

# Upstash Redis for booking rate limiting (https://upstash.com)
# Optional in dev — when unset, rate limiting is disabled.
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_token_here"
