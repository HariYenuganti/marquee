# Local Postgres
DATABASE_URL="postgresql://user:password@localhost:5432/marquee"

# Public site URL — used for metadata, OG tags, sitemap, robots.
# Set this to your production URL when you deploy (e.g. https://marquee.app).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Resend API key for booking confirmation emails (https://resend.com)
# Optional in dev — when unset, emails are a no-op.
RESEND_API_KEY="re_your_api_key_here"

# Upstash Redis for booking rate limiting (https://upstash.com)
# Optional in dev — when unset, rate limiting is disabled.
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_token_here"
